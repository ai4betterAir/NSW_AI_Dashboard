# Optional. Leave unset to use the shared forecast CSV folder:
# /mnt/scratch_lustre/ar_aichem_scratch/Nawcasting_Dashboard_Files
# CSV_DATA_FILE_PATH=/absolute/path/to/forecast_csv_folder

# Maximum age permitted for fallback observations. Older snapshots are shown
# as unavailable rather than being presented as current data.
DASHBOARD_OBS_CACHE_MAX_AGE_HOURS=6
DASHBOARD_PURPLEAIR_CACHE_MAX_AGE_HOURS=2

# Optional permitted mirror/relay when the official service blocks the
# dashboard host's egress IP. The relay must expose the same /get_* routes.
# NSW_AQMS_API_BASE_URL=https://data.airquality.nsw.gov.au/api/Data

# Official hourly HTML report used automatically when the JSON API blocks the
# deployment host.
# NSW_AQMS_CURRENT_REPORT_URL=https://airquality.environment.nsw.gov.au/aquisnetnswphp/getPage.php?reportid=2

# Official SEED feature service used for current rural/DustWatch station rows.
# NSW_DUSTWATCH_FEATURE_URL=https://portal.data.nsw.gov.au/arcgis/rest/services/Hosted/Air_Quality_Index_Public/FeatureServer/0/query

# API or dashboard port. Scripts provide sensible defaults.
PORT=8050

# Optional. Free localhost.run tunnels can expire; rotate before that happens.
# Set 0 to disable proactive rotation.
TUNNEL_MAX_AGE_SECONDS=1800

# Optional. Keep this only in local .env, never in git.
# Required for automatic GitHub Pages current.json publishing after restarts.
# GITHUB_TOKEN=github_pat_...
